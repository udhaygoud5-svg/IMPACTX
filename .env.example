# ─────────────────────────────────────────────────────────────
# ImpactX — Environment Variables
# Copy this file to .env.local and fill in your actual values.
# NEVER commit .env.local to git.
# ─────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────
# Get these from: https://supabase.com → Your Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key-here

# ── Google Sheets Webhook (optional) ──────────────────────────
# Create a Google Apps Script Web App that accepts POST requests
# and appends rows to your sheet. Paste its deployed URL below.
NEXT_PUBLIC_GOOGLE_SHEETS_URL=https://script.google.com/macros/s/your-script-id/exec

# ── Site URL (used for OpenGraph, canonical URLs) ─────────────
NEXT_PUBLIC_SITE_URL=https://impactx.co
